# GradientLens Environment Variables
# Copy this file to .env.local and fill in your values.

# DigitalOcean Gradient AI model access key (required)
DO_GRADIENT_MODEL_ACCESS_KEY=

# Optional overrides
DO_GRADIENT_BASE_URL=https://inference.do-ai.run
# Model IDs
DO_GRADIENT_TEXT_MODEL=llama3.3-70b-instruct
DO_GRADIENT_VISION_MODEL=openai-gpt-4o-mini

# TTS (Self-hosted Kokoro)
KOKORO_TTS_URL=https://inference.do-ai.run/v1/audio/speech

# DigitalOcean Managed Redis connection string (optional)
# REDIS_URL=rediss://default:password@host:port
REDIS_URL=

# Session memory TTL in seconds (default: 86400 / 24h)
MEMORY_TTL_SECONDS=86400
